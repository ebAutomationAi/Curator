# ─── Karakeep ───────────────────────────────────────────────────────────────
KARAKEEP_VERSION=release
NEXTAUTH_SECRET=                    # openssl rand -base64 36
NEXTAUTH_URL=http://192.168.1.33:3000  # cambiar a https://karakeep.curator-kiko.duckdns.org tras configurar NPM

# ─── Meilisearch ─────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=                   # openssl rand -base64 36

# ─── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=                          # Token del bot (BotFather)
TELEGRAM_CHAT_ID=                   # Chat ID del usuario (para notificaciones)

# ─── IA — Primario ───────────────────────────────────────────────────────────
GEMINI_API_KEY=                     # Google AI Studio — free tier

# ─── IA — Fallback ───────────────────────────────────────────────────────────
GROQ_API_KEY=                       # Opcional — activar si Gemini falla

# ─── Curator Service (se completa en Fase 2) ─────────────────────────────────
KARAKEEP_API_KEY=                   # Generado tras primer arranque de Karakeep
KARAKEEP_URL=http://karakeep:3000

# ─── Sistema ─────────────────────────────────────────────────────────────────
NODE_ENV=production
TZ=Europe/Madrid
