# ─── Karakeep ────────────────────────────────────────────────────────────────
# Pin to a specific version to avoid Meilisearch key desync on uncontrolled updates.
# Check https://github.com/karakeep-app/karakeep/releases for latest version.
KARAKEEP_VERSION=0.32.0

# openssl rand -base64 36
NEXTAUTH_SECRET=

# Internal LAN for initial setup. Change to your public HTTPS URL after configuring
# Nginx Proxy Manager (e.g. https://karakeep.your-subdomain.duckdns.org).
NEXTAUTH_URL=http://YOUR_LAN_IP:3000

# ─── Meilisearch ─────────────────────────────────────────────────────────────
# openssl rand -base64 36
MEILI_MASTER_KEY=

# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=

# Your personal chat ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=

# Set to true for initial setup (polling mode). Switch to false once webhook is configured.
TELEGRAM_POLLING=true

# ─── AI — Primary ────────────────────────────────────────────────────────────
# Google AI Studio free tier: https://aistudio.google.com
GEMINI_API_KEY=

# ─── AI — Fallback ───────────────────────────────────────────────────────────
# Optional but recommended. Activates automatically when Gemini quota is exhausted.
# https://console.groq.com
GROQ_API_KEY=

# ─── Curator Service ─────────────────────────────────────────────────────────
# Generate in Karakeep under Settings → API Keys after first startup.
KARAKEEP_API_KEY=

# Internal Docker hostname — do not change unless you rename the karakeep container.
KARAKEEP_URL=http://karakeep:3000

# ─── System ──────────────────────────────────────────────────────────────────
NODE_ENV=production
TZ=Europe/Madrid

# Optional: Healthchecks.io check UUID for external uptime monitoring.
HEALTHCHECK_UUID=

# ─── SMTP (Karakeep) ──────────────────────────────────────────────────────
[email protected]
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME= 

